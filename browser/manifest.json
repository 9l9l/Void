{
    "manifest_version": 3,
    "minimum_chrome_version": "111",
    "name": "Void",
    "description": "A modification for grok.com",
    "author": "Void Contributors",
    "homepage_url": "https://github.com/9l9l/Void",
    "host_permissions": [
        "*://grok.com/*"
    ],
    "permissions": [
        "declarativeNetRequest"
    ],
    "content_scripts": [
        {
            "run_at": "document_start",
            "matches": [
                "*://grok.com/*"
            ],
            "js": [
                "content.js"
            ],
            "all_frames": true,
            "world": "ISOLATED"
        },
        {
            "run_at": "document_start",
            "matches": [
                "*://grok.com/*"
            ],
            "js": [
                "dist/Void.js"
            ],
            "all_frames": true,
            "world": "MAIN"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "dist/*"
            ],
            "matches": [
                "*://grok.com/*"
            ]
        }
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "modifyResponseHeaders",
                "enabled": true,
                "path": "modifyResponseHeaders.json"
            }
        ]
    }
}
