{
    "manifest_version": 2,
    "minimum_chrome_version": "91",
    "name": "Void",
    "description": "A modification for grok.com",
    "author": "Void Contributors",
    "homepage_url": "https://github.com/9l9l/Void",
    "permissions": [
        "webRequest",
        "webRequestBlocking",
        "*://grok.com/*"
    ],
    "content_scripts": [
        {
            "run_at": "document_start",
            "matches": [
                "*://grok.com/*"
            ],
            "js": [
                "content.js"
            ],
            "all_frames": true,
            "world": "ISOLATED"
        },
        {
            "run_at": "document_start",
            "matches": [
                "*://grok.com/*"
            ],
            "js": [
                "dist/Void.js"
            ],
            "all_frames": true,
            "world": "MAIN"
        }
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "web_accessible_resources": [
        "dist/Void.js"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "firefox@void.o9",
            "strict_min_version": "128.0"
        }
    }
}
