# Void Development Guidelines

rules:
  critical:
    licenseHeader: NEVER edit existing license headers, new files use 2026
    noComments: NEVER add comments unless explicitly asked, keep existing comments
    noGitCheckout: NEVER git checkout files without explicit permission
    pushBack: push back when the user idea is wrong or not correct
    useMCP: always use void-mcp MCP tools to check Grok's live code instead of guessing
    afterBuild: after `bun run build`, ask user to reload Grok page and restart MCP server (`bun run mcp`)
    checkDeprecated: always verify components/functions arent deprecated before using
    minimalChanges: fix with smallest possible change, no refactoring unless explicitly asked
    noOverengineering: solve the problem at hand only, no patterns for patterns sake
    commands: you can run `bun run lint:fix`, `bun run lint:styles:fix`, `bun run tsc` after changes. NEVER run `bun run build` unless explicitly asked
    humanText: write natural human text in errors, descriptions, messages. No dashes or robotic formatting
    descriptions: capital first letter, end with period
  code:
    fileOrder: imports → Logger → turbopack finders → interfaces/types → const globals → functions/components → definePlugin/export default
    deleteNotComment: DELETE dead code, dont comment it, git preserves history
    noHardcoded: no hardcoded values, magic numbers, string literals that should be constants
    minimal: KISS over clever, flat over nested, explicit over implicit. Less code is always better
    namedVars: prefer a well-named variable when it clarifies intent, inline only when the expression is already obvious
    earlyReturn: guard clause and return early, never nest 3+ levels deep
    performance: Map/Set over object lookups, .some/.find over .filter[0], no spread in loops, Promise.all for parallel async
    logger: use Logger from @utils/Logger, NEVER raw console.log/warn/error
    classNames: import classNameFactory from @utils/css, prefix MUST end with `-` (e.g. `classNameFactory("void-foo-")`), use `cl("bar")` not `cl("-bar")` or `cl("")`, use `cl("root")` for root element. ONLY use cl() for our own custom CSS class names — never for Grok's Tailwind/design-token classes (e.g. use `"text-fg-danger"` directly, not `cl("danger")`)
    classJoin: use `classes()` from @utils/css to combine cl() with Tailwind or other classes, not template strings like `${a} ${b}`
    useExisting: use utilities from @utils/, @api/, @components/, @turbopack/common/. Check barrel exports (components/index.ts) before creating new finders
  typescript:
    prefer: optional chaining (?.), nullish coalescing (??), const, arrow functions, satisfies over as
    use: destructuring, template literals, object shorthand, array methods, readonly where immutable
    style: trust inference for locals, annotate exports/params, inline single-use variables
    generics: constrain with extends, default type params where sensible
    enums: const enum for fixed sets (zero runtime cost, inlined). as const objects when you need runtime key iteration or computed values
    typing: proper type > any > unknown. Use any for turbopack finders/module exports, Proxy handlers. Use unknown for user input, error params, JSON parse
    grokTypes: NEVER use any for Grok objects when types exist in packages/grok-types/, import proper types
  react:
    errorBoundary: wrap complex components with ErrorBoundary.wrap(Component, { noop: true })
    nullNotUndefined: return null for conditional rendering not undefined
    cleanup: always return cleanup functions in useEffect
    keys: stable unique keys, never array index
    memoization: useMemo/useCallback only when measurably needed, not by default
    forbidden: React.cloneElement, React.isValidElement, React.memo(), React.lazy, React.Children
  css:
    componentsFirst: prefer Flex/Grid for flex/grid layouts, Text/Paragraph for styled text. Plain <div>/<span> are fine for simple wrappers or containers that dont need layout logic. Tailwind className for styling
    noInlineStyles: prefer Tailwind className or styles.css with cl() over style={{}}. Inline styles are acceptable for dynamic computed values, layout component internals (Flex/Grid), and settingsTabs section padding
    tailwindWithCl: when combining cl() classes with Tailwind, use `classes(cl("foo"), "tailwind-class")`. Never pass raw Tailwind into cl() since it prefixes everything
    pluginCSS: always name styles.css
    runtimeCSS: registerStyle(name, css) for runtime injection
  forbidden:
    DOM: direct DOM manipulation (use patches)
    emptyCatch: empty catch blocks (except turbopack module iteration)
    settingsArrays: NEVER use settings.use() with arrays, mutate then reassign
    nestedTernaries: NEVER nest ternaries, use early returns or variables
    mutateParams: NEVER mutate function parameters, clone or return new
  neverHardcode:
    console: console.log/warn/error ⟹ Logger from @utils/Logger
    classConcat: "`${a} ${b}`" ⟹ classes(a, b) from @utils/css
    perFileFinders: findByPropsLazy for common modules ⟹ import from @turbopack/common/*
    perFileStores: findByPropsLazy("useXxxStore") ⟹ typed import from @turbopack/common/stores
    nullGuards: ⟹ isTruthy, isNonNullish from @utils/misc
    clipboard: navigator.clipboard ⟹ copyToClipboard from @utils/misc
    repeatedDelays: repeated setTimeout for the same event ⟹ debounce from @utils/misc. One-shot setTimeout is fine
  antiPatterns:
    "value !== null && value !== undefined" ⟹ "value != null"
    "array && array.length > 0" ⟹ "array.length"
    "settings?.store?.value" ⟹ "settings.store.value"
    "value || defaultValue" ⟹ "value ?? defaultValue"
    "arr.filter(x => x.id === id)[0]" ⟹ "arr.find(x => x.id === id)"
    "Object.keys(obj).length === 0" ⟹ "!Object.keys(obj).length"
    "new Promise((res) => { fetch().then(res) })" ⟹ "fetch()"
    "if (x) { return true } else { return false }" ⟹ "return x"
    "arr.forEach(x => newArr.push(transform(x)))" ⟹ "arr.map(transform)"
    "[...arr1, ...arr2] in loops" ⟹ "arr1.concat(arr2) or push(...arr2)"

settingsTabs:
  layout: Wrapper div handles flex-1, w-full, h-full, padding, overflow-scroll. Tab components NEVER set width/height/overflow/flex:1 or create inner scroll containers. Root = bare `<Flex flexDirection="column" gap="...">`. Use Tailwind className for sizing/spacing
  consistency: verify against Grok's native settings appearance using MCP tools

structure:
  apis: src/api/ — logic, types, state management (registries, stores, pub/sub). No patches, no UI rendering
  corePlugins: src/plugins/_core/ and _api/ — patch Grok to inject API functionality. Pattern: API in src/api/ → Core plugin patches to inject it
  components: src/components/ — custom Void components only, no turbopack finders. Icons in src/components/icons/
  grokComponents: src/turbopack/common/components.ts — all Grok native wrappers via LazyComponent + findExportedComponent
  addingGrokComponent: 1. type in packages/grok-types/components.d.ts → 2. LazyComponent wrapper in common/components.ts → 3. re-export from components/index.ts
  grokTypes: packages/grok-types/ — TypeScript type definitions for Grok runtime (stores, components, enums). No runtime code
  plugins: |
    src/plugins/<name>/index.ts(x) — plugin entry, uses definePlugin
    Folder suffix conventions: .dev (dev builds only), .chrome (Chromium only, hidden otherwise)
    Load order: _core/ → _api/ → regular plugins

patching:
  core:
    surgical: minimum code touched, one patch per concern, shortest regex wins
    verify: ALWAYS use MCP patch test before finalizing, NEVER guess module structure (if using MCP)
    iterate: try multiple approaches, keep simplifying until you find the cleanest solution
    minimize: if removing a token still gives one match, remove it
    anchor: every match MUST contain a stable string literal (component name, i18n key, prop name). Pure \i chains break
  tokens:
    \i: "(?:[A-Za-z_$][\\w$]*)" — any JS identifier, glue between anchors
    \e{Name}: target named exports in e.s([...])
    "#{i18n::KEY}": i18n string literals (dots escaped)
    $self: Void.plugins["PluginName"]
    $&: entire matched string (append/prepend without capture groups)
    "$1, $2": capture group refs, only when reusing captured content
  find:
    unique: MUST match exactly 1 module (or shared factory group), verify with MCP
    anchors: i18n keys, exported component names, feature flags, CSS class strings
    shared: use `all: true` for shared factories
  options:
    all: apply to all factory instances, required for shared factories
    group: atomic rollback if any replacement fails
    predicate: conditionally skip patch at registration time
    noWarn: suppress "no effect" warnings
  match:
    append: use $& to append/prepend, no capture groups needed
    gate: prepend guard with $& like "!$self._check()&&$&"
    lookbehind: "(?<=stableAnchor)" to anchor without consuming
    lookahead: "(?=context)" to verify what comes next, wide .{0,N} safe since non-consuming
    capture: only when reusing content in replace
    group: use group:true for multi-step transforms instead of one massive regex
    gaps: .{0,N} ALWAYS, NEVER .*? or .+?, set N to ~1.5x actual distance
    flexible: \i(?:\|\|\i)+ not \i\|\|\i\|\|\i
  NEVER:
    hardcodedMinified: e,t,n,r,i,o,s,l,c,u ⟹ \i
    unboundedGaps: .+? or .*? ⟹ .{0,N}
    pureIdentifiers: /\i\|\|\i/ alone ⟹ pair with string literal
    captureReassembly: ($1)($2)($3) ⟹ $& append, lookbehind, or group:true
    deepNesting: ]\}\)\]\}\) as capture groups ⟹ match up to anchor, use $&
    massiveRegex: split multi-step into group:true replacements

finding:
  core: ALWAYS verify finders match exactly 1 module via MCP. Use 2+ props. NEVER single-char/common prop names. Use @turbopack/common/* over per-file findByPropsLazy
  stores: ALWAYS import from @turbopack/common/stores. NEVER per-plugin findByPropsLazy("useXxxStore"). If store missing, add it there first
  storeTyping: 1. interfaces in packages/grok-types/stores/ → 2. enums in packages/grok-types/enums/ → 3. export from barrel → 4. typed finder in common/stores.ts

pluginInterop:
  checkEnabled: isPluginEnabled(name) from @api/PluginManager
  settings: use definePluginSettings from @api/Settings, not inline settings object
